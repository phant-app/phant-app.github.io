---
import '../styles/landing.css';
import updateManifest from '../data/update.json';
import BaseHead from '../components/BaseHead.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import Nav from '../components/landing/Nav.astro';
import Hero from '../components/landing/Hero.astro';
import Features from '../components/landing/Features.astro';
import Roadmap from '../components/landing/Roadmap.astro';
import Pricing from '../components/landing/Pricing.astro';
import Author from '../components/landing/Author.astro';
import Footer from '../components/landing/Footer.astro';

const pageTitle = "Phant — Local PHP & Laravel Development Toolkit for Linux";
const currentVersion = typeof updateManifest.version === 'string' ? updateManifest.version : '';
---

<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead title={pageTitle} description={SITE_DESCRIPTION} />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: SITE_TITLE,
        url: new URL("/", Astro.site),
        description: SITE_DESCRIPTION,
      })}
    />
  </head>
  <body>
    <div class="grid-bg"></div>
    <Nav />
    <Hero version={currentVersion} />
    <Features />
    <Roadmap />
    <Pricing />
    <Author />
    <Footer />
  </body>
</html>
