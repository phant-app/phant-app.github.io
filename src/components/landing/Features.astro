---
import { Image } from "astro:assets";
import phpManagerImage from "../../assets/php-manager.png";
import sitesImage from "../../assets/sites.png";
import dumpsImage from "../../assets/dumps.png";
import servicesImage from "../../assets/services.png";
---

<section id="features" class="py-24">
  <div class="wrap">
    <div class="mb-11 flex items-baseline gap-3.5 border-b border-[var(--phant-border)] pb-3.5">
      <h2 class="m-0 text-[clamp(1.7rem,5vw,2.4rem)] uppercase tracking-[-0.01em] text-[var(--phant-white)]">
        Capability <span class="text-[var(--phant-purple)] drop-shadow-[0_0_15px_rgba(139,92,246,0.4)]">Matrix</span>
      </h2>
      <small class="font-['JetBrains_Mono'] text-[0.65rem] uppercase tracking-[0.14em] text-[var(--phant-text)]">
        Core systems offline
      </small>
    </div>

    <div class="grid grid-cols-1 gap-4 min-[761px]:grid-cols-2">
      <article class="flex min-h-full flex-col overflow-hidden rounded-lg border border-[var(--phant-border)] bg-[var(--phant-bg-soft)]">
        <div class="flex items-center justify-between gap-2.5 border-b border-[var(--phant-border)] bg-[#0d0d14] px-4 py-3 font-['JetBrains_Mono'] text-[0.72rem]">
          <span class="font-bold text-[var(--phant-purple)]">&gt; _ PHP MANAGER</span>
          <span class="text-right text-[0.6rem] uppercase tracking-[0.08em] text-[var(--phant-muted)]">runtime switcher</span>
        </div>
        <div class="flex h-full flex-col p-[18px]">
          <div class="mb-4 overflow-hidden rounded-md border border-[var(--phant-border)] bg-[#090912]">
            <Image src={phpManagerImage} alt="Phant PHP Manager screen" class="h-auto w-full" />
          </div>
          <p class="mb-4 text-[0.96rem] leading-[1.7]">
            Move between PHP versions with confidence per project. Validate active runtime instantly and reduce
            environment drift before it turns into team-wide debugging noise.
          </p>
          <div class="mt-auto rounded-md border border-[var(--phant-border)] bg-black/40 p-2.5 font-['JetBrains_Mono'] text-[0.74rem] leading-[1.6] text-[var(--phant-muted)]">
            <div class="flex justify-between"><span>Current</span><span class="text-[var(--phant-purple)]">PHP 8.4</span></div>
            <div class="flex justify-between"><span>Project API</span><span class="text-[var(--phant-text)]">8.3 pinned</span></div>
          </div>
        </div>
      </article>

      <article class="flex min-h-full flex-col overflow-hidden rounded-lg border border-[var(--phant-border)] bg-[var(--phant-bg-soft)]">
        <div class="flex items-center justify-between gap-2.5 border-b border-[var(--phant-border)] bg-[#0d0d14] px-4 py-3 font-['JetBrains_Mono'] text-[0.72rem]">
          <span class="font-bold text-[var(--phant-purple)]">&gt; _ SITES</span>
          <span class="text-right text-[0.6rem] uppercase tracking-[0.08em] text-[var(--phant-muted)]">cpriego/valet-linux</span>
        </div>
        <div class="flex h-full flex-col p-[18px]">
          <div class="mb-4 overflow-hidden rounded-md border border-[var(--phant-border)] bg-[#090912]">
            <Image src={sitesImage} alt="Phant Sites screen with linked and parked local domains" class="h-auto w-full" />
          </div>
          <p class="mb-4 text-[0.96rem] leading-[1.7]">
            Track linked and parked projects in one place. Switch PHP versions per app, assign local TLS, and keep
            runtime context visible without bouncing between shell scripts.
          </p>
          <div class="mt-auto rounded-md border border-[var(--phant-border)] bg-black/40 p-2.5 font-['JetBrains_Mono'] text-[0.74rem] leading-[1.6] text-[var(--phant-muted)]">
            <div class="flex justify-between"><span>phant.test</span><span class="text-[var(--phant-purple)]">8.4</span></div>
            <div class="flex justify-between"><span>app.test</span><span class="text-[var(--phant-purple)]">8.3</span></div>
          </div>
        </div>
      </article>

      <article class="flex min-h-full flex-col overflow-hidden rounded-lg border border-[var(--phant-border)] bg-[var(--phant-bg-soft)]">
        <div class="flex items-center justify-between gap-2.5 border-b border-[var(--phant-border)] bg-[#0d0d14] px-4 py-3 font-['JetBrains_Mono'] text-[0.72rem]">
          <span class="font-bold text-[var(--phant-purple)]">&gt; _ DUMPS</span>
          <span class="text-right text-[0.6rem] uppercase tracking-[0.08em] text-[var(--phant-muted)]">prepend hook render</span>
        </div>
        <div class="flex h-full flex-col p-[18px]">
          <div class="mb-4 overflow-hidden rounded-md border border-[var(--phant-border)] bg-[#090912]">
            <Image src={dumpsImage} alt="Phant Dumps screen displaying dump and dd output" class="h-auto w-full" />
          </div>
          <p class="mb-4 text-[0.96rem] leading-[1.7]">
            Capture dump() and dd() output live through prepend hooks. Inspect structured payloads in a native panel
            instead of hunting through browser responses.
          </p>
          <div class="mt-auto rounded-md border border-[var(--phant-border)] bg-black p-2.5 font-['JetBrains_Mono'] text-[0.74rem] leading-[1.6] text-[var(--phant-muted)]">
            <span class="text-sky-400">App\Models\User</span> <span class="text-white">#2136</span><br />
            <span class="text-[var(--phant-text)]">#table:</span> <span class="text-amber-500">"users"</span><br />
            <span class="text-[var(--phant-text)]">+exists:</span> <span class="text-[var(--phant-purple)]">true</span><br />
            <span class="text-white">}</span>
          </div>
        </div>
      </article>

      <article class="flex min-h-full flex-col overflow-hidden rounded-lg border border-[var(--phant-border)] bg-[var(--phant-bg-soft)]">
        <div class="flex items-center justify-between gap-2.5 border-b border-[var(--phant-border)] bg-[#0d0d14] px-4 py-3 font-['JetBrains_Mono'] text-[0.72rem]">
          <span class="font-bold text-[var(--phant-purple)]">&gt; _ SERVICES</span>
          <span class="text-right text-[0.6rem] uppercase tracking-[0.08em] text-[var(--phant-muted)]">daemon state</span>
        </div>
        <div class="flex h-full flex-col p-[18px]">
          <div class="mb-4 overflow-hidden rounded-md border border-[var(--phant-border)] bg-[#090912]">
            <Image src={servicesImage} alt="Phant Services screen with local service status" class="h-auto w-full" />
          </div>
          <p class="mb-4 text-[0.96rem] leading-[1.7]">
            See service state at a glance. Confirm queues, databases, and cache backends instantly, so your local
            stack matches the environment you think is running.
          </p>
          <div class="mt-auto flex flex-wrap gap-1.5 rounded-md border border-[var(--phant-border)] bg-black/40 p-2.5 font-['JetBrains_Mono'] text-[0.74rem] leading-[1.6] text-[var(--phant-muted)]">
            <span class="border border-green-900 bg-green-950 px-1.5 py-[3px] text-[10px] uppercase text-green-500">Valkey / :6379</span>
            <span class="border border-red-900 bg-red-950 px-1.5 py-[3px] text-[10px] uppercase text-red-500">MariaDB / Null</span>
            <span class="border border-[var(--phant-border)] bg-[var(--phant-black)] px-1.5 py-[3px] text-[10px] uppercase text-[var(--phant-text)]">Postgres</span>
            <span class="border border-[var(--phant-border)] bg-[var(--phant-black)] px-1.5 py-[3px] text-[10px] uppercase text-[var(--phant-text)]">Redis</span>
            <span class="border border-[var(--phant-border)] bg-[var(--phant-black)] px-1.5 py-[3px] text-[10px] uppercase text-[var(--phant-text)]">MySQL</span>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>