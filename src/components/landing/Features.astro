---
import { Image } from "astro:assets";
import phpManagerImage from "../../assets/php-manager.png";
import sitesImage from "../../assets/sites.png";
import dumpsImage from "../../assets/dumps.png";
import servicesImage from "../../assets/services.png";

const capabilities = [
  {
    key: "php",
    title: "PHP Manager",
    subtitle: "Runtime Switcher",
    description:
      "Install and switch PHP versions from your Linux package manager while keeping CLI/runtime context visible per project.",
    bullets: [
      "Tune PHP and PHP-FPM configuration parameters without leaving the app.",
      "Enable or disable extensions depending on project needs.",
      "Reduce environment mismatch before debugging starts.",
    ],
    officialSourceLabel: "Official PHP install guide",
    officialSourceHref: "https://www.php.net/manual/en/install.unix.php",
    image: phpManagerImage,
    alt: "Phant PHP manager screen showing installed versions and switch actions",
  },
  {
    key: "sites",
    title: "Sites",
    subtitle: "Valet Integration",
    description:
      "Manage linked and parked local domains in one place. Keep domain, PHP version, and SSL context easy to verify.",
    bullets: [
      "Track linked and parked projects at a glance.",
      "See assigned PHP versions for each local domain.",
      "Reduce context switching between terminal and browser.",
    ],
    image: sitesImage,
    alt: "Phant Sites screen listing local projects, URLs, and PHP versions",
  },
  {
    key: "dumps",
    title: "Dumps",
    subtitle: "Live Inspector",
    description:
      "Capture dump() and dd() output from terminal commands, local sites, and Tinker in one native panel for faster debugging.",
    bullets: [
      "Read structured output in a focused app-native view.",
      "Trace values across CLI, browser routes, and Tinker sessions.",
      "Especially helpful when debugging complex flows.",
    ],
    image: dumpsImage,
    alt: "Phant Dumps screen showing live dump and dd output",
  },
  {
    key: "services",
    title: "Services",
    subtitle: "Daemon State",
    description:
      "Confirm local service health instantly for queues, databases, and cache layers so your environment matches your intent.",
    bullets: [
      "See service status in one unified panel.",
      "Validate ports and units quickly.",
      "Avoid silent local infra issues during development.",
    ],
    image: servicesImage,
    alt: "Phant Services screen with local daemon status cards",
  },
];
---

<section id="features" class="py-24">
  <div class="wrap">
    <div class="mb-11 flex flex-wrap items-baseline gap-3.5 border-b border-[var(--phant-border)] pb-3.5">
      <h2 class="m-0 text-[clamp(1.7rem,5vw,2.4rem)] uppercase tracking-[-0.01em] text-[var(--phant-white)]">
        Capability <span class="text-[var(--phant-purple)] drop-shadow-[0_0_15px_rgba(139,92,246,0.4)]">Matrix</span>
      </h2>
      <small class="font-['JetBrains_Mono'] text-[0.65rem] uppercase tracking-[0.14em] text-[var(--phant-text)]">
        Product Storyboard
      </small>
    </div>

    <div class="space-y-8 min-[980px]:space-y-10">
      {
        capabilities.map((capability, index) => (
          <article class="group grid overflow-hidden rounded-xl border border-[var(--phant-border)] bg-[var(--phant-bg-soft)] shadow-[0_18px_45px_rgba(0,0,0,0.28)] min-[980px]:grid-cols-2">
            <div
              class:list={[
                "relative overflow-hidden border-b border-[var(--phant-border)] bg-[#06060d] min-[980px]:border-b-0",
                index < 2 ? "min-[980px]:order-2 min-[980px]:border-l" : "min-[980px]:order-1 min-[980px]:border-r",
              ]}
            >
              <Image
                src={capability.image}
                alt={capability.alt}
                class="h-[250px] w-full object-cover bg-[#05050a] p-2 transition duration-500 group-hover:scale-110 min-[980px]:h-[320px]"
              />
              <div class="pointer-events-none absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-[#06060d] to-transparent"></div>
            </div>
            <div class:list={["flex h-full flex-col p-6 min-[980px]:p-8", index < 2 ? "min-[980px]:order-1" : "min-[980px]:order-2"]}>
              <div class="mb-3 flex items-start justify-between gap-3">
                <h3 class="m-0 text-[1.55rem] font-extrabold uppercase tracking-[-0.01em] text-[var(--phant-white)] min-[980px]:text-[1.75rem]">{capability.title}</h3>
                <span class="rounded border border-[#3a2f56] bg-[#151025] px-2 py-1 font-['JetBrains_Mono'] text-[0.6rem] uppercase tracking-[0.1em] text-violet-300">
                  {capability.subtitle}
                </span>
              </div>

              <p class="mb-4 text-[0.96rem] leading-[1.7] text-[var(--phant-text)]">{capability.description}</p>

              {
                capability.officialSourceHref && (
                  <p class="mb-4 font-['JetBrains_Mono'] text-[0.68rem] uppercase tracking-[0.08em] text-[#9f9fb0]">
                    Official source: {" "}
                    <a
                      href={capability.officialSourceHref}
                      target="_blank"
                      rel="noreferrer"
                      class="text-violet-300 no-underline transition hover:text-violet-200"
                    >
                      {capability.officialSourceLabel}
                    </a>
                  </p>
                )
              }

              <ul class="m-0 list-disc space-y-1.5 pl-5 text-[0.9rem] leading-[1.65] text-[#b8b8c8]">
                {capability.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>