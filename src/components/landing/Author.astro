<section id="author" class="relative py-24">
  <div class="pointer-events-none absolute inset-x-0 top-10 mx-auto h-56 w-[min(980px,92%)] rounded-full bg-[radial-gradient(circle_at_center,rgba(244,114,182,0.16),rgba(5,5,8,0))] blur-2xl"></div>

  <div class="wrap">
    <div class="relative overflow-hidden rounded-2xl border border-[var(--phant-border)] bg-[linear-gradient(135deg,#0b0b12_0%,#11101a_45%,#140e1e_100%)] p-6 shadow-[0_25px_80px_rgba(0,0,0,0.45)] min-[901px]:p-10">
      <div class="absolute -top-16 -right-10 h-48 w-48 rounded-full bg-[rgba(192,132,252,0.2)] blur-3xl"></div>
      <div class="absolute -bottom-16 -left-10 h-48 w-48 rounded-full bg-[rgba(244,114,182,0.14)] blur-3xl"></div>

      <div class="relative grid grid-cols-1 gap-8 min-[901px]:grid-cols-[220px_1fr] min-[901px]:items-center">
        <div class="flex flex-col items-center gap-4">
          <img
            src="https://avatars.githubusercontent.com/u/41125008?v=4"
            alt="Ronald Pereira avatar"
            class="h-40 w-40 rounded-2xl border border-[rgba(255,255,255,0.22)] object-cover shadow-[0_18px_45px_rgba(0,0,0,0.45)]"
            loading="lazy"
            decoding="async"
          />
          <span class="inline-flex items-center rounded-md border border-[var(--phant-border)] bg-black/35 px-3 py-1 font-['JetBrains_Mono'] text-[10px] uppercase tracking-[0.22em] text-[var(--phant-text)]">
            Creator
          </span>
        </div>

        <div>
          <p class="mb-3 font-['JetBrains_Mono'] text-xs uppercase tracking-[0.18em] text-[var(--phant-pink)]">
            Who is the author?
          </p>
          <h2 class="mb-4 text-[clamp(1.9rem,4.5vw,3.2rem)] leading-[1.02] tracking-[-0.03em] text-white">
            Ronald Pereira
          </h2>
          <p class="max-w-3xl text-[1.02rem] leading-[1.8] text-[var(--phant-text)]">
            Ronald is a developer who enjoys solving complex puzzles with software. Phant is built from that mindset:
            simplify the hard parts of local PHP and Laravel development while keeping power and precision close at hand.
          </p>

          <blockquote class="mt-5 border-l-2 border-[var(--phant-purple)] pl-4 font-['JetBrains_Mono'] text-sm leading-[1.8] text-[var(--phant-white)]/85">
            Build less friction. Ship more ideas.
          </blockquote>

          <div class="mt-7 flex flex-wrap gap-3">
            <a
              href="https://rondevz.github.io"
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center justify-center rounded-md border border-[var(--phant-border)] bg-white px-4 py-[10px] font-['JetBrains_Mono'] text-[0.7rem] font-bold uppercase tracking-[0.1em] text-(--phant-black) no-underline transition hover:bg-(--phant-purple) hover:text-white"
            >
              Portfolio
            </a>
            <a
              href="https://github.com/rondevz"
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center justify-center rounded-md border border-[var(--phant-border)] bg-[#0c0c12] px-4 py-[10px] font-['JetBrains_Mono'] text-[0.7rem] uppercase tracking-[0.1em] text-white no-underline transition hover:border-(--phant-purple)"
            >
              GitHub Profile
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>